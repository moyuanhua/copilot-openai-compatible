# Required
PROXY_API_KEY=your-secret-proxy-key

# Optional — GitHub token for server-side Copilot authentication
# If not set the proxy will use the logged-in GitHub CLI user
# GITHUB_TOKEN=ghp_...

# Optional — enable passthrough mode (clients supply X-GitHub-Token header)
# ENABLE_PASSTHROUGH=false

# Optional
# PORT=3000
# LOG_LEVEL=info
# RATE_LIMIT_MAX=60
# RATE_LIMIT_WINDOW_MS=60000
# DEFAULT_MODEL=gpt-4.1
# CUSTOM_MODEL_MAP={"my-model":"gpt-4.1"}
