{
  "name": "copilot-openai-compatible",
  "version": "1.0.0",
  "description": "OpenAI-compatible proxy server backed by GitHub Copilot SDK",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "test": "jest --forceExit",
    "test:coverage": "jest --coverage --forceExit"
  },
  "keywords": [
    "openai",
    "copilot",
    "proxy",
    "llm"
  ],
  "license": "MIT",
  "dependencies": {
    "@github/copilot-sdk": "^0.1.32",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.2",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
